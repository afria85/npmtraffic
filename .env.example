# Public site URLs (used for canonical + OG generation in non-Vercel environments)
# If unset, npmtraffic will infer from request headers in production.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=https://npmtraffic.com
# BASE_URL=https://npmtraffic.com
# SITE_URL=https://npmtraffic.com

# Project links (used in header/footer)
NEXT_PUBLIC_PROJECT_GITHUB=https://github.com/afria85/npmtraffic

# Optional donation links (surface on /donate)
# NEXT_PUBLIC_DONATE_GITHUB_SPONSORS=
# NEXT_PUBLIC_DONATE_KOFI=
# NEXT_PUBLIC_DONATE_BMAC=
# NEXT_PUBLIC_DONATE_PAYPAL=

# Optional distributed rate limiting (recommended for serverless)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional cron/prewarm auth. Required in production for /api/cron/prewarm.
# CRON_SECRET=

# Security headers
# Set to 1 to emit a stricter CSP in Report-Only mode (use browser console to validate violations)
# CSP_REPORT_ONLY=1

# Testing helper (simulates upstream failures in traffic fetch paths)
# NPMTRAFFIC_TEST_UPSTREAM_FAIL=1
